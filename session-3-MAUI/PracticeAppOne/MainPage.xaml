<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PracticeAppOne.MainPage">

    <ScrollView>
        <Grid RowDefinitions="*, *, 2*" Padding="30.0">
            <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Image Source="dotnet_bot.png" HeightRequest="50"/>
                <Image Source="dotnet_bot.png" HeightRequest="50"/>
            </HorizontalStackLayout>
            <Label Grid.Row="1" Text="HELLO WORLD LABEL" VerticalOptions="Center" HorizontalOptions="Center"/>
            <VerticalStackLayout Grid.Row="2" VerticalOptions="Center">
                <Button 
                    Grid.Row="2"
                    x:Name="CounterBtn"
                    Text="One"
                    HorizontalOptions="Center"
                    MinimumWidthRequest="75"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
